# --- Telegram ---
TELEGRAM_BOT_TOKEN=put-your-botfather-token-here

# --- Chat LLM (OpenAI-compatible endpoint) ---
# Any OpenAI-compatible /v1 server: vLLM, llama.cpp, LM Studio, TGI, a gateway.
# No temperature and no max_tokens are sent; server defaults decide.
# From inside docker-compose, localhost is the bot container. Use
# host.docker.internal to reach a server on the host, e.g.
# http://host.docker.internal:8000/v1
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=local

# harrier-oss-v1-270m is an embedding model and cannot drive the interview.
# These must name chat/instruct models served on OPENAI_BASE_URL.
DIALOG_MODEL=local-chat
EXTRACT_MODEL=local-chat
SUMMARY_MODEL=local-chat
EVAL_MODEL=local-chat
# Semantic grounding judge for extracted items. May equal EVAL_MODEL during
# prototype, but can be stricter/stronger in production.
GROUND_MODEL=local-chat

# Session token budget (prompt+completion). Soft cap injects a wrap-up nudge
# into STATE; hard cap forces end_session. 0 disables.
SOFT_CAP_TOKENS=120000
HARD_CAP_TOKENS=200000

# --- Embeddings: optional harrier-oss-v1-270m ---
# disabled: no vector dedup/RAG; safe default.
# bundled: scripts/run.ps1 starts scripts/serve_embed.py locally. Before using
#          it, run: powershell -File scripts\setup.ps1 -WithEmbeddings
# external: use an already running OpenAI-compatible /v1 embeddings endpoint.
EMBED_MODE=disabled

# For bundled mode, EMBED_BASE_URL may be left empty; the app defaults to
# http://127.0.0.1:8300/v1. For external mode, set it explicitly.
EMBED_BASE_URL=
EMBED_PORT=8300
EMBED_DEVICE=auto
EMBED_READY_TIMEOUT_SEC=180
EMBED_API_KEY=local
EMBED_MODEL=microsoft/harrier-oss-v1-270m
DEDUP_SAME=0.15
DEDUP_NEAR=0.35
RAG_MAX_DISTANCE=0.55

# --- Web search: Tavily (optional) ---
# Empty = web_search/web_fetch tools hidden.
TAVILY_API_KEY=

# --- STT: voice messages via local GigaAM v3 + Silero VAD (optional) ---
# Empty = voice disabled.
# Install/cache models: powershell -File scripts\setup.ps1 -WithStt
# Run the service: python -m scripts.serve_stt
# STT_BASE_URL=http://localhost:8301
STT_BASE_URL=
STT_MODEL=v3_e2e_rnnt
STT_DEVICE=auto
# STT_MAX_VOICE_SEC=600
# STT_MAX_SEC=900

# --- Postgres ---
# Default localhost = primary workflow: Postgres in Docker, bot as local process.
# docker-compose overrides this to host "db" for the containerized bot.
DATABASE_URL=postgresql://kb:kb@localhost:5432/kb

# --- Watchdog tuning ---
BOT_RESTART_INITIAL_DELAY_SEC=5
BOT_RESTART_MAX_DELAY_SEC=60
BOT_RESTART_MAX_FAST_FAILURES=3
