# --- Telegram ---
TELEGRAM_BOT_TOKEN=put-your-botfather-token-here

# --- Chat LLM (OpenAI-compatible endpoint) ---
# Any OpenAI-compatible /v1 server: vLLM, llama.cpp, LM Studio, TGI, a gateway.
# No temperature and no max_tokens are ever sent; server defaults decide.
# From inside docker-compose, localhost is the container — use host.docker.internal
# to reach a server on the host, e.g. http://host.docker.internal:8000/v1
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=local

# NOTE: harrier-oss-v1-270m is an EMBEDDING model and CANNOT drive the interview.
# These must name a chat/instruct model served on OPENAI_BASE_URL.
DIALOG_MODEL=local-chat
EXTRACT_MODEL=local-chat
SUMMARY_MODEL=local-chat
EVAL_MODEL=local-chat

# Session token budget (prompt+completion). Soft cap injects a "wrap up" nudge
# into STATE; hard cap forces end_session. Tune from first live runs. 0 disables.
SOFT_CAP_TOKENS=120000
HARD_CAP_TOKENS=200000

# --- Embeddings: local harrier-oss-v1-270m — OPTIONAL ---
# Powers dedup-on-insert + the search_knowledge tool. Leave EMBED_BASE_URL empty
# to run without: items stay canonical, search_knowledge returns nothing, the
# collection loop still works. Serve harrier with text-embeddings-inference to
# expose /v1/embeddings, then set the URL. dim = 640 (must match the migration).
# Weights are already downloaded to ./models/harrier-oss-v1-270m.
EMBED_BASE_URL=
EMBED_API_KEY=local
EMBED_MODEL=microsoft/harrier-oss-v1-270m
DEDUP_SAME=0.15
DEDUP_NEAR=0.35

# --- Web search: Tavily — OPTIONAL ---
# Lets the interviewer verify hardware/terms mid-reasoning before building a
# question on a wrong prior. Empty = web_search/web_fetch tools hidden. Free
# tier ~1000 req/mo at app.tavily.com.
TAVILY_API_KEY=

# --- Postgres ---
# Inside docker-compose the host is "db"; for local runs use "localhost".
DATABASE_URL=postgresql://kb:kb@db:5432/kb
